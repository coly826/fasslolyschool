</div>

<div class="text-end mt-3 no-print">
<button onclick="printMembers()" class="btn btn-success">
<i class="bi bi-printer"></i> Imprimer la liste
</button>
</div>

</div>
</div>
</div>

</div>

<script>
function showMembers() {

const section = document.getElementById('membersSection');

if(section.style.display === 'none'){
    section.style.display = 'block';
    section.scrollIntoView({ behavior: 'smooth' });
}else{
    section.style.display = 'none';
}

}

function printMembers() {

const content = document.getElementById('membersSection').innerHTML;

const printWindow = window.open('', '', 'width=900,height=700');

printWindow.document.write(`
<html>
<head>
<title>Liste des membres</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    padding:30px;
    font-family:Arial;
}

table{
    width:100%;
}

h2,h4{
    text-align:center;
}

img{
    display:block;
    margin:auto;
}
</style>

</head>

<body>
${content}

<script>
window.onload = function(){
    window.print();
    window.close();
}
<\/script>

</body>
</html>
`);

printWindow.document.close();

}
</script>

<%- include('partials/footer') %>