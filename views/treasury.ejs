<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-5 print-area">

<!-- LOGO + TITRE -->
<div class="text-center mb-4">
    <img src="/image/logolo.jpeg" style="height:90px;">
    <h3>AEE R-FASS LOLY</h3>
    <h4 class="text-primary">TABLEAU DES COTISATIONS</h4>
</div>

<!-- FORM -->
<form action="/treasury/add" method="POST" class="row g-2 mb-4 no-print">

<div class="col-md-4">
<input type="text" name="nom" class="form-control" placeholder="Nom" required>
</div>

<div class="col-md-3">
<input type="number" name="montant" class="form-control" placeholder="Montant" required>
</div>

<div class="col-md-3">
<select name="mois" class="form-select" required>
<option value="">Mois</option>
<option>Janvier</option>
<option>Février</option>
<option>Mars</option>
<option>Avril</option>
<option>Mai</option>
<option>Juin</option>
<option>Juillet</option>
<option>Août</option>
<option>Septembre</option>
<option>Octobre</option>
<option>Novembre</option>
<option>Décembre</option>
</select>
</div>

<div class="col-md-2">
<button class="btn btn-success w-100">Ajouter</button>
</div>

</form>

<!-- TOTAL -->
<%
let safeTreasury = treasury || [];
let total = 0;
safeTreasury.forEach(t => total += Number(t.montant || 0));
%>

<h4 class="text-end text-success mb-4">
Total : <%= total.toLocaleString() %> CFA
</h4>

<!-- TABLE -->
<div class="table-responsive">

<table class="table table-bordered table-hover text-center align-middle">

<thead class="table-dark">
<tr>
<th>Nom</th>
<th>Mois</th>
<th>Montant</th>
<th class="no-print">Action</th>
</tr>
</thead>

<tbody>

<% safeTreasury.forEach(t => { %>
<tr>
<td><%= t.nom %></td>
<td><%= t.mois %></td>
<td><%= Number(t.montant).toLocaleString() %> CFA</td>
<td class="no-print">
<a href="/treasury/delete/<%= t._id %>" 
class="btn btn-danger btn-sm">
Supprimer
</a>
</td>
</tr>
<% }) %>

</tbody>

</table>

</div>

<!-- BUTTONS -->
<div class="d-flex justify-content-end gap-2 mt-4 no-print">

<button onclick="showMembers()" class="btn btn-primary">
<i class="bi bi-people-fill"></i> Liste des membres
</button>

<button onclick="window.print()" class="btn btn-dark">
<i class="bi bi-printer"></i> Imprimer
</button>

</div>

<!-- MEMBERS TABLE -->
<div id="membersSection" class="mt-5" style="display:none;">

<div class="card shadow-lg border-0">

