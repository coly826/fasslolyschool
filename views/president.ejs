<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-5 print-area">

    <!-- HEADER IMPRESSION -->
    <div class="text-center mb-4">

        <img src="/image/logolo.jpeg" style="height:90px;" class="mb-2">

        <h3>AEE R-FASS LOLY</h3>
        <h4 class="text-primary">ESPACE PRÉSIDENT</h4>

        <!-- 👇 NOM DU PRÉSIDENT -->
        <h5 class="mt-3">
            Président :
            <span class="text-dark fw-bold">
                <% if (members && members.length > 0) { %>
                    <%= members[0].name %>
                <% } else { %>
                    Non défini
                <% } %>
            </span>
        </h5>

        <p class="text-muted">Rapport des activités</p>

    </div>

    <!-- BOUTON IMPRIMER -->
    <div class="text-end no-print mb-3">
        <button onclick="window.print()" class="btn btn-dark">
            🖨 Imprimer
        </button>
    </div>

    <div class="row">

        <!-- PRESIDENT -->
        <div class="col-md-4 no-print">
            <div class="card p-3 shadow-sm text-center">

                <h5>Président(s)</h5>

                <% (members || []).forEach(m => { %>
                    <p><strong><%= m.name %></strong></p>
                <% }) %>

            </div>
        </div>

        <!-- FORMULAIRE -->
        <div class="col-md-8 no-print">
            <div class="card p-3 shadow-sm">

                <h5 class="mb-3 text-success">Ajouter une activité</h5>

                <form action="/president/add-task" method="POST">

                    <input type="text" name="titre" class="form-control mb-2" placeholder="Titre" required>

                    <textarea name="description" class="form-control mb-3" placeholder="Description" required></textarea>

                    <button class="btn btn-primary w-100">Ajouter</button>

                </form>

            </div>
        </div>

    </div>

    <!-- LISTE ACTIVITES -->
    <div class="mt-5">

        <h4 class="text-center mb-4">Liste des activités</h4>

        <div class="row">

            <% (tasks || []).forEach(t => { %>

                <div class="col-md-6 mb-3">

                    <div class="card p-3 shadow-sm text-center">

                        <h5 class="text-primary"><%= t.titre %></h5>

                        <p><%= t.description %></p>

                        <small class="text-muted">
                            Date : <%= new Date(t.date).toLocaleDateString() %>
                        </small>
                        

                        <!-- SUPPRESSION -->
                        <div class="mt-2 no-print">
                            <a href="/president/delete-task/<%= t._id %>" class="btn btn-danger btn-sm">
                                Supprimer
                            </a>
                        </div>

                    </div>
                    <a href="/" class="btn btn-secondary">
                        <i class="bi bi-house-door-fill"></i>
                        Retour Accueil
                    </a>
                

                </div>

            <% }) %>

        </div>

    </div>

</div>

<%- include('partials/footer') %>